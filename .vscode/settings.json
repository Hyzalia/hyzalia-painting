{
  "java.import.gradle.enabled": true,
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.import.gradle.wrapper.enabled": true,
  "java.dependency.packagePresentation": "hierarchical",
  "java.compile.nullAnalysis.mode": "automatic",

  "java.format.enabled": true,
  "java.format.settings.lineSplit": 80,
  "java.format.settings.url": ".vscode/java-formatter.xml",
  "java.format.settings.profile": "Hyzalia",
  "java.format.settings.insertSpaceBeforeSemicolonInForStatements": false,
  "java.format.settings.insertSpaceAfterCommaInMethodInvocationArguments": true,
  "editor.formatOnSave": true,
  "[java]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  }
}
